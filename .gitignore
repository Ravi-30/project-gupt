# ============================================
# Keep These
# ============================================

# Keep empty directories
!.gitkeep

# Keep documentation
!*.md
!LICENSE

# Keep source files
!*.swift
!*.h
!*.m
!*.metal

# Keep project configuration
!Info.plist
!*.entitlements
!*.xcconfig
!Package.swift

# Keep assets
!Assets.xcassets/
!*.xcassets/**

# Keep storyboards and XIBs
!*.storyboard
!*.xib

# Keep resource files
!*.strings
!*.stringsdict
!*.json
!*.plist
!*.lproj/

# ============================================
# Notes
# ============================================

# This .gitignore is configured for:
# - Swift macOS application
# - Xcode project
# - Swift Package Manager
# - Security (no keys/certificates)
# - Clean repository
